<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- QUAN TRỌNG: Đường dẫn root của external storage -->
    <external-path
        name="external_storage_root"
        path="." />

    <!-- Đường dẫn đến thư mục Download/MCBELauncher -->
    <external-path
        name="mcbe_launcher_downloads"
        path="Download/MCBELauncher/" />

    <!-- Đường dẫn chung cho thư mục Download -->
